# Mission Control — Environment Configuration
#
# Copy this file to .env (already gitignored) and change any values you want
# to override. All defaults are production-safe for local use; most installs
# need no changes beyond WATCH_PROJECT_PATH.
#
# Variables prefixed NEXT_PUBLIC_ are inlined into the browser bundle at
# build time — they are NOT secret.


# === Server ===

# Port the Next.js server binds to (used by `pnpm dev` and `pnpm start`).
PORT=10000


# === Branding ===

# Application name shown in the header and page title.
NEXT_PUBLIC_APP_NAME="Mission Control"

# Short subtitle shown in meta description and dashboard header.
NEXT_PUBLIC_APP_DESCRIPTION="Agent Mission Control Dashboard"


# === Watching ===

# Absolute path to the project Mission Control should observe.
# Leave unset to watch the directory MC is launched from.
# WATCH_PROJECT_PATH=/home/you/projects/MyApp

# Path to the team-kit folder (agent definitions, prompts).
# Defaults to <MC install>/team-kit at runtime — only set if you've moved it.
# MC_TEAM_KIT_SOURCE=/home/you/projects/MyApp/team-kit

# Path to the watch-agent.mjs script.
# Defaults to <MC install>/scripts/watch-agent.mjs — only set if you've moved it.
# MC_WATCH_SCRIPT_PATH=/home/you/projects/MyApp/scripts/watch-agent.mjs


# === Persistence ===

# Directory where Mission Control persists snapshot state between restarts.
MC_STATE_DIR=~/.mission-control/state

# Path to the MC config JSON file. Used by tests to inject a custom config.
MC_CONFIG_PATH=~/.mission-control/config.json


# === Runtime Tunables ===

# How often (ms) the watcher polls JSONL files for new events.
MC_POLL_INTERVAL_MS=750

# An agent is considered "active" if it produced an event within this window (ms).
MC_AGENT_ACTIVE_THRESHOLD_MS=30000

# An agent is considered "completed" if idle longer than this window (ms).
MC_AGENT_COMPLETED_THRESHOLD_MS=60000

# Debounce delay (ms) before a changed snapshot is persisted to disk.
MC_SNAPSHOT_SAVE_DEBOUNCE_MS=1000

# How many bytes from the tail of each JSONL file to read on cold start.
MC_JSONL_LOOKBACK_BYTES=786432

# Number of recent tool names tracked per agent.
MC_MAX_RECENT_TOOLS=20

# Lookback window (ms) for counting "recent" tool uses per agent.
MC_RECENT_TOOLUSE_WINDOW_MS=60000

# Maximum characters included in a prompt preview.
MC_PROMPT_PREVIEW_CHARS=500

# Events included in each persisted snapshot (server-side).
MC_SNAPSHOT_EVENT_LIMIT=200


# === Networking / SSE ===

# Maximum number of concurrent SSE client connections.
MC_MAX_SSE_CONNECTIONS=10

# Interval (ms) between SSE keep-alive heartbeat pings.
MC_SSE_HEARTBEAT_MS=15000

# Maximum events replayed to a client on SSE reconnect.
MC_MAX_REPLAY_EVENTS=500

# Server-side ring buffer cap for recent events.
MC_EVENT_RING_BUFFER_SIZE=500

# Maximum events returned by a single API fetch request.
MC_MAX_EVENTS_PER_REQUEST=500

# Default page size for event list API responses.
MC_DEFAULT_EVENTS_LIMIT=200

# Client-side cap on events held in memory (browser).
NEXT_PUBLIC_MC_CLIENT_EVENT_LIMIT=200


# === Database ===

# Prisma / docker-compose database connection string.
# Not actively read by app code today, but kept for forward-compatibility
# when a persistent relational store is added.
DATABASE_URL="file:./dev.db"


# === Docker (compose only) ===
# Host port to bind Mission Control to on your machine
MC_HOST_PORT=10000
# Port the container listens on internally
MC_CONTAINER_PORT=10000


# === Multi-host ===
# Identifier for this MC install's own host. Appears as the "local" host in the UI.
MC_HOST_ID=local

# Human-friendly label for MC's own host (optional).
# MC_HOST_LABEL="my-laptop"

# Comma-separated bearer tokens accepted at /api/ingest. Leave empty to disable
# ingest entirely (single-host mode). Generate with: openssl rand -hex 32
# MC_INGEST_TOKENS=

# Max /api/ingest body size in bytes (default 5 MB).
MC_MAX_INGEST_BODY_BYTES=5242880

# Rate limit burst per token (default 100).
MC_INGEST_RATE_BURST=100

# Rate limit refill rate per second per token (default 10).
MC_INGEST_RATE_REFILL_PER_SEC=10
